#!/usr/bin/env bash
# Resolves the plugin venv (created by /init-workspace); falls back to
# system python3/python pre-setup. Every skill/step file invokes THIS
# via `npx @shahboura/harness`, which routes through the npm bin symlink.
# On Windows the Bash tool is Git Bash, so this same script runs there too:
# the venv layout is Scripts/python.exe, and `python3` frequently doesn't
# exist (python.org installs ship only `python`) — probe both. bin/
# harness.cmd is the cmd.exe sibling for non-bash callers.
set -euo pipefail
# Resolve through npm's node_modules/.bin symlink to the real package dir
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
HERE="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PY="$HERE/../.venv/bin/python"
[ -x "$PY" ] || PY="$HERE/../.venv/Scripts/python.exe"
[ -x "$PY" ] || PY="$(command -v python3 || command -v python || echo python3)"
# `python -m harness` only resolves the package if the repo root is on
# sys.path; callers run this from their TARGET workspace (config is
# written relative to cwd, and --workspace defaults to it), never from
# this repo, so PYTHONPATH — not `cd` — is what makes it importable
# without disturbing that cwd.
exec env PYTHONPATH="$HERE/.." "$PY" -m harness "$@"
